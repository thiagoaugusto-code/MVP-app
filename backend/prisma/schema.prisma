// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      String   @default("USER")  // USER, COLLABORATOR, NUTRITIONIST, PERSONAL, INSTRUCTOR, COACH
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mealLogs           MealLog[]
  workoutLogs        WorkoutLog[]
  progressLogs       ProgressLog[]
  dailyChecks        DailyCheck[]
  insights           Insight[]
  notifications      Notification[]
  
  studentProfile     StudentProfile?
  collaboratorProfile CollaboratorProfile?
  
  // Relação para colaborador que acompanha múltiplos alunos
  managedStudents    StudentProfile[]  @relation("CollaboratorStudents")
}

model MealLog {
  id        Int      @id @default(autoincrement())
  name      String
  calories  Int
  protein   Int?
  carbs     Int?
  fat       Int?
  mealType  String   // breakfast, lunch, dinner, snack
  date      DateTime @default(now())
  completed Boolean  @default(true)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id        Int      @id @default(autoincrement())
  name      String
  duration  Int      // in minutes
  intensity String?  // light, moderate, high
  exercises String?  // JSON stringified array
  completed Boolean  @default(true)
  date      DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressLog {
  id     Int      @id @default(autoincrement())
  weight Float?
  bodyFat Float?
  notes  String?
  date   DateTime @default(now())
  userId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Insight {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   // motivation, achievement, tip, warning
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   // reminder, achievement, tip
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyCheck {
  id     Int      @id @default(autoincrement())
  type   String   // water, sleep, meal, workout, custom
  value  Int?     // for water (ml), sleep (hours)
  done   Boolean  @default(false)
  date   DateTime @default(now())
  userId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}

model StudentProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            String?  // weight loss, muscle gain, maintenance
  currentWeight   Float?
  targetWeight    Float?
  height          Float?
  collaboratorId  Int?     // FK para colaborador que acompanha
  collaborator    User?    @relation("CollaboratorStudents", fields: [collaboratorId], references: [id], onDelete: SetNull)
  joinedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CollaboratorProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty    String   // nutritionist, personal trainer, instructor, coach
  codeOrCRM    String?  // CREF, CRN, etc
  bio          String?
  experience   Int?     // years
  phone        String?
  studentsCount Int    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}