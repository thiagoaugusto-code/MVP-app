// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      String   @default("USER")  // USER, COLLABORATOR, NUTRITIONIST, PERSONAL, INSTRUCTOR, COACH
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mealLogs           MealLog[]
  workouts           Workout[]
  progressLogs       ProgressLog[]
  dailyChecks        DailyCheck[]
  insights           Insight[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  
  studentProfile     StudentProfile?
  collaboratorProfile CollaboratorProfile?
  
  // Relação para colaborador que acompanha múltiplos alunos
  managedStudents    StudentProfile[]  @relation("CollaboratorStudents")
  
  // Novos relacionamentos
  studentCollaborators StudentCollaborator[] @relation("StudentCollaborators")
  collaboratorStudents StudentCollaborator[] @relation("CollaboratorStudents")
  meals               Meal[]
  mealSuggestions     MealSuggestion[]
  
  // Chat relacionamentos
  studentConversations    Conversation[] @relation("StudentConversations")
  collaboratorConversations Conversation[] @relation("CollaboratorConversations")
  sentMessages            Message[]
  aiChats                 AIChat[]
  chatMetrics             ChatMetrics?
  dailyUserStates         DailyUserState[]
}

/// Materialized per-day aggregate: single read model for dashboard, checklist, calendar.
model DailyUserState {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local calendar day key YYYY-MM-DD (server interprets with local dayRange helpers).
  date            DateTime
  waterMl          Int      @default(0)
  waterGoalMl      Int      @default(2000)
  sleepHours       Float?
  caloriesGoal     Int      @default(2000)
  mealsGoal        Int      @default(3)
  workoutGoal      Int      @default(3)
  caloriesConsumed Int      @default(0)
  progressScore    Int      @default(0)
  calendarStatus   String   @default("red") // green | yellow | red
  workoutCompleted Boolean  @default(false)

  /// JSON string: [{ id, name, durationMin, completed, secondsDone }]
  exercises        String?
  /// JSON string: snapshot of meals
  mealsSnapshot    String?
  /// JSON string: checklist items
  checklist        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model MealLog {
  id        Int      @id @default(autoincrement())
  name      String
  calories  Int
  protein   Int?
  carbs     Int?
  fat       Int?
  mealType  String   // breakfast, lunch, dinner, snack
  date      DateTime @default(now())
  completed Boolean  @default(true)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id         Int      @id @default(autoincrement())

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date       DateTime @default(now())
  completed  Boolean  @default(false)

  activities WorkoutActivity[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, date])
}

model WorkoutActivity {
  id         Int      @id @default(autoincrement())
  workoutId  Int
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  name       String
  sets       Int?
  reps       Int?
  duration   Int? // segundos ou minutos

  completed  Boolean @default(false)

  updatedAt DateTime @updatedAt
}

model ProgressLog {
  id     Int      @id @default(autoincrement())
  weight Float?
  bodyFat Float?
  notes  String?
  date   DateTime @default(now())
  userId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Insight {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   // motivation, achievement, tip, warning
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   // reminder, achievement, tip
  priority  String?  @default("normal")
  metadata  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint     String   @unique
  subscription String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DailyCheck {
  id     Int      @id @default(autoincrement())
  type   String   // water, sleep, meal, workout, custom
  value  Int?     // for water (ml), sleep (hours)
  done   Boolean  @default(false)
  date   DateTime @default(now())
  userId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}

model StudentProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            String?  // weight loss, muscle gain, maintenance
  currentWeight   Float?
  targetWeight    Float?
  height          Float?
  collaboratorId  Int?     // FK para colaborador que acompanha
  collaborator    User?    @relation("CollaboratorStudents", fields: [collaboratorId], references: [id], onDelete: SetNull)
  joinedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CollaboratorProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty    String   // nutritionist, personal trainer, instructor, coach
  codeOrCRM    String?  // CREF, CRN, etc
  bio          String?
  experience   Int?     // years
  phone        String?
  price        Float?   // placeholder price
  focus        String?  // specialty focus
  studentsCount Int    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StudentCollaborator {
  id             Int      @id @default(autoincrement())
  studentId      Int
  student        User     @relation("StudentCollaborators", fields: [studentId], references: [id], onDelete: Cascade)
  collaboratorId Int
  collaborator   User     @relation("CollaboratorStudents", fields: [collaboratorId], references: [id], onDelete: Cascade)
  specialty      String   // nutritionist, personal, instructor, coach
  status         String   @default("pending") // pending, approved, rejected
  active         Boolean  @default(false)
  requestedAt    DateTime @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  updatedAt      DateTime @updatedAt

  @@unique([studentId, specialty, active]) // only one active per specialty
}

model Meal {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime  @default(now())
  mealType      String    // breakfast, lunch, dinner, snack, pre_workout, post_workout
  completed     Boolean   @default(false)
  totalCalories Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  foodItems     FoodItem[]

  @@unique([userId, date, mealType])
}

model FoodItem {
  id        Int     @id @default(autoincrement())
  mealId    Int
  meal      Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name      String
  quantity  Float
  unit      String  // g, ml, unit
  calories  Int
  protein   Int?
  carbs     Int?
  fat       Int?
  time      DateTime? // horário, e.g., "08:00"
  notes     String?
  createdAt DateTime @default(now())
}

model MealSuggestion {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType   String
  aiMode     String?  // objective, motivational, hardcore, welcoming
  suggestions String? // JSON string of suggested foods
  createdAt  DateTime @default(now())
}

model Conversation {
  id                Int       @id @default(autoincrement())
  studentId         Int
  student           User      @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  collaboratorId    Int
  collaborator      User      @relation("CollaboratorConversations", fields: [collaboratorId], references: [id], onDelete: Cascade)
  messages          Message[]
  lastMessage       String?
  lastMessageAt     DateTime?
  studentUnread     Int       @default(0)
  collaboratorUnread Int     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([studentId, collaboratorId])
}

model Message {
  id              Int         @id @default(autoincrement())
  conversationId  Int
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        Int
  sender          User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content         String
  type            String      @default("text") // text, quick_action, suggestion
  metadata        String?     // JSON for quick actions or suggestions
  isAI            Boolean     @default(false)
  aiMode          String?     // mode used if isAI=true
  readAt          DateTime?
  createdAt       DateTime    @default(now())
}

model AIChat {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode            String    // direct, welcoming, hardcore, preventive, celebration
  prompt          String
  response        String
  tokensUsed      Int       @default(0)
  cost            Float     @default(0)
  cached          Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

model ChatMetrics {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyTokens     Int       @default(0)
  dailyTokensDate DateTime?
  lastResetAt     DateTime  @default(now())
  totalCost       Float     @default(0)
}