PORT=3000
DATABASE_URL="file:./dev.db"
JWT_SECRET=supersecretkey
FRONTEND_URL=http://localhost:5174

# === ADMIN ACCESS ===
# Set secure credentials for admin login
# ⚠️ NEVER expose these in frontend or version control
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SecureAdminPassword123!

# === AI INTEGRATION ===
# OpenAI Configuration (production recommended)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4-turbo
AI_API_TIMEOUT=30000

# Claude Configuration (optional fallback)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# AI Behavior Settings
AI_DAILY_TOKEN_LIMIT=50000
AI_CACHE_DURATION=3600000
AI_DEBOUNCE_MS=5000

# === EMAIL NOTIFICATIONS ===
EMAIL_FROM=no-reply@example.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password

# === PUSH NOTIFICATIONS ===
# Generate keys: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_EMAIL=notifications@example.com

# === ENVIRONMENT ===
NODE_ENV=development
LOG_LEVEL=debug
